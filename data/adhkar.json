  "morning": [
    {
      "text": "سيد الاستغفار: اللهم أنت ربي لا إله إلا أنت...",
      "repeat": 1,
      "source": "البخاري",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "أصبحنا وأصبح الملك لله... أسألك خير ما في هذا اليوم...",
      "repeat": 1,
      "source": "مسلم",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "اللهم بك أصبحنا وبك أمسينا وبك نحيا وبك نموت وإليك النشور",
      "repeat": 1,
      "source": "السنن",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "سبحان الله وبحمده",
      "repeat": 100,
      "source": "مسلم/البخاري",
      "ref": "https://dorar.net/hadith/sharh/40346"
    },
    {
      "text": "بسم الله الذي لا يضر مع اسمه شيء في الأرض ولا في السماء وهو السميع العليم",
      "repeat": 3,
      "source": "أبو داود/الترمذي",
      "ref": "https://islamqa.info/ar/answers/126587"
    },
    {
      "text": "رضيت بالله ربًا وبالإسلام دينًا وبمحمد ﷺ نبيًا",
      "repeat": 3,
      "source": "السنن",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "الإخلاص والفلق والناس",
      "repeat": 3,
      "source": "السنن",
      "ref": "https://islamqa.info/ar/answers/217496"
    }
  ],
  "evening": [
    {
      "text": "أمسينا وأمسى الملك لله... أسألك خير ما في هذه الليلة...",
      "repeat": 1,
      "source": "مسلم",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "اللهم بك أمسينا وبك أصبحنا وبك نحيا وبك نموت وإليك المصير",
      "repeat": 1,
      "source": "السنن",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "سبحان الله وبحمده",
      "repeat": 100,
      "source": "مسلم",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "أعوذ بكلمات الله التامات من شر ما خلق",
      "repeat": 3,
      "source": "مسلم",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "بسم الله الذي لا يضر...",
      "repeat": 3,
      "source": "أبو داود/الترمذي",
      "ref": "https://islamqa.info/ar/answers/126587"
    },
    {
      "text": "الإخلاص والفلق والناس",
      "repeat": 3,
      "source": "السنن",
      "ref": "https://islamqa.info/ar/answers/217496"
    }
  ],
  "sleep": [
    {
      "text": "جمع الكفين والنفث وقراءة الإخلاص والمعوذتين ثم مسح الجسد",
      "repeat": 3,
      "source": "البخاري",
      "ref": "https://islamqa.info/ar/answers/145543"
    },
    {
      "text": "آية الكرسي",
      "repeat": 1,
      "source": "البخاري",
      "ref": "https://dorar.net/hadith/sharh/141083"
    },
    {
      "text": "آخر آيتين من سورة البقرة (285–286)",
      "repeat": 1,
      "source": "البخاري/مسلم",
      "ref": "https://islamqa.info/ar/answers/145543"
    },
    {
      "text": "باسمك اللهم أموت وأحيا",
      "repeat": 1,
      "source": "البخاري",
      "ref": "https://islamqa.info/ar/answers/145543"
    },
    {
      "text": "تسبيح فاطمة (33/33/34)",
      "repeat": 1,
      "source": "الصحيحين",
      "ref": "https://islamqa.info/ar/answers/145543"
    }
  ],
  "afterPrayer": [
    {
      "text": "أستغفر الله (ثلاثًا) ثم: اللهم أنت السلام ومنك السلام...",
      "repeat": 1,
      "source": "مسلم",
      "ref": "https://islamweb.net/ar/fatwa/4514/%D8%A3%D8%B0%D9%83%D8%A7%D8%B1-%D8%A7%D9%84%D9%86%D9%88%D9%85"
    },
    {
      "text": "سبحان الله 33، الحمد لله 33، الله أكبر 33، ثم تمام المئة: لا إله إلا الله وحده لا شريك له...",
      "repeat": 1,
      "source": "ثابت",
      "ref": "https://binbaz.org.sa/fatwas/23415/%D9%85%D8%A7-%D8%A7%D9%84%D8%B5%D8%AD%D9%8A%D8%AD-%D9%85%D9%86-%D8%A7%D9%84%D8%A7%D8%B0%D9%83%D8%A7%D8%B1-%D9%81%D9%8A-%D8%A7%D9%84%D8%B5%D8%A8%D8%A7%D8%AD-%D9%88%D8%A7%D9%84%D9%85%D8%B3%D8%A7%D8%A1"
    }
  ],
  "daily": [
    {
      "text": "عند الخروج: بسم الله، توكلت على الله، ولا حول ولا قوة إلا بالله",
      "repeat": 1,
      "source": "حصن المسلم/السنن",
      "ref": "https://islamqa.info/ar/answers/217496"
    },
    {
      "text": "عند دخول المنزل: بسم الله ولجنا وبسم الله خرجنا وعلى ربنا توكلنا",
